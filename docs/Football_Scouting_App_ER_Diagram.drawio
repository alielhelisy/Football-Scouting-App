<mxfile host="app.diagrams.net" modified="2026-05-04T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="football-scouting-erd" name="Football Scouting App ERD">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Football Scouting App - ER Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="420" y="30" width="560" height="50" as="geometry" />
        </mxCell>

        <mxCell id="users" value="&lt;div style=&quot;font-size:18px;font-weight:700;text-align:center;margin-bottom:8px&quot;&gt;users&lt;/div&gt;&lt;table cellpadding=&quot;4&quot; cellspacing=&quot;0&quot; style=&quot;width:100%;font-size:13px&quot;&gt;&lt;tr&gt;&lt;td&gt;PK id&lt;/td&gt;&lt;td&gt;INT IDENTITY PK&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;username&lt;/td&gt;&lt;td&gt;NVARCHAR(100) UNIQUE NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;name&lt;/td&gt;&lt;td&gt;NVARCHAR(100) NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;surname&lt;/td&gt;&lt;td&gt;NVARCHAR(100) NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;email&lt;/td&gt;&lt;td&gt;NVARCHAR(255) NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;password_hash&lt;/td&gt;&lt;td&gt;NVARCHAR(64) NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;role&lt;/td&gt;&lt;td&gt;NVARCHAR(10) DEFAULT 'SCOUT'&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#2563eb;strokeWidth=2;arcSize=6;spacing=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="390" height="270" as="geometry" />
        </mxCell>

        <mxCell id="players" value="&lt;div style=&quot;font-size:18px;font-weight:700;text-align:center;margin-bottom:8px&quot;&gt;players&lt;/div&gt;&lt;table cellpadding=&quot;4&quot; cellspacing=&quot;0&quot; style=&quot;width:100%;font-size:13px&quot;&gt;&lt;tr&gt;&lt;td&gt;PK id&lt;/td&gt;&lt;td&gt;INT IDENTITY PK&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;FK user_id&lt;/td&gt;&lt;td&gt;INT FK -> users.id&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;name&lt;/td&gt;&lt;td&gt;NVARCHAR(100) NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;gender&lt;/td&gt;&lt;td&gt;NVARCHAR(10) DEFAULT 'Male'&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;team&lt;/td&gt;&lt;td&gt;NVARCHAR(100) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;position&lt;/td&gt;&lt;td&gt;NVARCHAR(20) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;other_position&lt;/td&gt;&lt;td&gt;NVARCHAR(20) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;first_name&lt;/td&gt;&lt;td&gt;NVARCHAR(100) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;last_name&lt;/td&gt;&lt;td&gt;NVARCHAR(100) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;nationality&lt;/td&gt;&lt;td&gt;NVARCHAR(100) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;birthday&lt;/td&gt;&lt;td&gt;DATE NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;height&lt;/td&gt;&lt;td&gt;INT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;weight&lt;/td&gt;&lt;td&gt;INT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;foot&lt;/td&gt;&lt;td&gt;NVARCHAR(10) DEFAULT ''&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;strokeWidth=2;arcSize=6;spacing=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="530" y="120" width="430" height="470" as="geometry" />
        </mxCell>

        <mxCell id="reports" value="&lt;div style=&quot;font-size:18px;font-weight:700;text-align:center;margin-bottom:8px&quot;&gt;reports&lt;/div&gt;&lt;table cellpadding=&quot;4&quot; cellspacing=&quot;0&quot; style=&quot;width:100%;font-size:13px&quot;&gt;&lt;tr&gt;&lt;td&gt;PK id&lt;/td&gt;&lt;td&gt;INT IDENTITY PK&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;FK player_id&lt;/td&gt;&lt;td&gt;INT FK -> players.id&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;rating&lt;/td&gt;&lt;td&gt;DECIMAL(2,1) CHECK 1-5 half steps&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;minutes_played&lt;/td&gt;&lt;td&gt;INT DEFAULT 0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;goals_scored&lt;/td&gt;&lt;td&gt;INT DEFAULT 0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;received_cards&lt;/td&gt;&lt;td&gt;NVARCHAR(10) DEFAULT 'None'&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;rated_position&lt;/td&gt;&lt;td&gt;NVARCHAR(20) NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;comments&lt;/td&gt;&lt;td&gt;NVARCHAR(MAX) NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;created_at&lt;/td&gt;&lt;td&gt;DATETIME DEFAULT GETDATE()&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;strokeWidth=2;arcSize=6;spacing=12;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="1020" y="190" width="360" height="330" as="geometry" />
        </mxCell>

        <mxCell id="rel_users_players" value="owns" style="endArrow=ERmany;startArrow=ERone;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#374151;fontSize=13;fontStyle=1;fontColor=#111827;" edge="1" parent="1" source="users" target="players">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rel_players_reports" value="has" style="endArrow=ERmany;startArrow=ERone;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#374151;fontSize=13;fontStyle=1;fontColor=#111827;" edge="1" parent="1" source="players" target="reports">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="note1" value="One user can create many players. Each player belongs to one user." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#d1d5db;fontSize=13;fontColor=#374151;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="110" y="510" width="330" height="70" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="One player can have many reports. Reports are deleted automatically when their player is deleted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#d1d5db;fontSize=13;fontColor=#374151;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1050" y="560" width="300" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
